// Tang Nano 20K physical constraints for tt_um_morse_converter (top.v)
//
// Pin facts from the Tang Nano 20K v1.2 schematic (Tang_Nano_20K_3921):
//   - 27 MHz oscillator on pin 4
//   - S2 = pin 87 (MODE1_KEY2); switches the pin to +3V3 through 330R when
//     pressed -> active high, pulled down here
//   - LED0 on pin 15, anode at +3V3 through 510R -> active low
//   - Header J5 carries pins 41, 42, 48, 80; header J6 carries pin 85
//     (pin numbers are printed on the board silkscreen)

// 27 MHz crystal
IO_LOC "clk" 4;
IO_PORT "clk" IO_TYPE=LVCMOS33 PULL_MODE=NONE;

// On-board button S2 (active high)
IO_LOC "btn_mute" 87;                            // S2: mute toggle
IO_PORT "btn_mute" IO_TYPE=LVCMOS33 PULL_MODE=DOWN;

// External reset: short this header pin to GND to reset
IO_LOC "rst_btn_n" 42;                           // J5
IO_PORT "rst_btn_n" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// Speed select jumpers -> wpm_sel[1:0]. Pull modes default to 2'b00, the
// slowest setting (~311 ms dit). Jumper to 3V3 to speed up.
// NOTE: must stay off pins 13/71-76/86; those are wired to the on-board
// BL616 MCU (HSPI nets), which can drive them and override the weak
// internal pulls. 41/42/48 go only to the unpopulated LCD FPC connector.
IO_LOC "speed[0]" 48;                            // J5, default 0 (pull-down)
IO_PORT "speed[0]" IO_TYPE=LVCMOS33 PULL_MODE=DOWN;
IO_LOC "speed[1]" 41;                            // J5, default 0 (pull-down)
IO_PORT "speed[1]" IO_TYPE=LVCMOS33 PULL_MODE=DOWN;

// On-board LEDs (active low). LED0 alone shows the morse key line while SOS
// is being sent; all six blink together during the pause between repeats.
IO_LOC "led_n[0]" 15;
IO_PORT "led_n[0]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "led_n[1]" 16;
IO_PORT "led_n[1]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "led_n[2]" 17;
IO_PORT "led_n[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "led_n[3]" 18;
IO_PORT "led_n[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "led_n[4]" 19;
IO_PORT "led_n[4]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "led_n[5]" 20;
IO_PORT "led_n[5]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;

// Audio + debug outputs (SDIO pins: only reach the unpopulated microSD slot)
IO_LOC "audio_pwm" 85;                           // J6, PWM sidetone (buzzer / scope)
IO_PORT "audio_pwm" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
IO_LOC "key_line" 80;                            // J5, clean morse key line (scope)
IO_PORT "key_line" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8;
